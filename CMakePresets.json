{
    "version": 5,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 22
    },
    "configurePresets": [
        {
            "name": "linux-gcc-debug",
            "displayName": "Linux GCC Debug (vcpkg)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/linux-gcc-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_COMPILER": "/usr/bin/g++-13",
                "CMAKE_CXX_STANDARD": "20",
                "CMAKE_TOOLCHAIN_FILE": "$env{HOME}/dev/vcpkg/scripts/buildsystems/vcpkg.cmake",
                "VCPKG_TARGET_TRIPLET": "x64-linux",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "linux-gcc-release",
            "displayName": "Linux GCC Release (vcpkg)",
            "inherits": "linux-gcc-debug",
            "binaryDir": "${sourceDir}/build/linux-gcc-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "linux-gcc-perf",
            "displayName": "Linux GCC RelWithDebInfo (perf, vcpkg)",
            "inherits": "linux-gcc-debug",
            "binaryDir": "${sourceDir}/build/linux-gcc-perf",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "CMAKE_CXX_FLAGS_RELWITHDEBINFO": "-O3 -g -fno-omit-frame-pointer"
            }
        },
        {
            "name": "linux-gcc-coverage",
            "displayName": "Linux GCC Coverage (vcpkg)",
            "inherits": "linux-gcc-debug",
            "binaryDir": "${sourceDir}/build/linux-gcc-coverage",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "UNIFIEDVOL_ENABLE_COVERAGE": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "linux-gcc-debug",
            "configurePreset": "linux-gcc-debug"
        },
        {
            "name": "linux-gcc-release",
            "configurePreset": "linux-gcc-release"
        },
        {
            "name": "linux-gcc-perf",
            "configurePreset": "linux-gcc-perf"
        },
        {
            "name": "linux-gcc-coverage",
            "configurePreset": "linux-gcc-coverage"
        },
        {
            "name": "linux-gcc-release-tests",
            "configurePreset": "linux-gcc-release",
            "targets": [
                "unifiedvol_tests"
            ]
        },
        {
            "name": "linux-gcc-perf-tests",
            "configurePreset": "linux-gcc-perf",
            "targets": [
                "unifiedvol_tests"
            ]
        },
        {
            "name": "linux-gcc-coverage-tests",
            "configurePreset": "linux-gcc-coverage",
            "targets": [
                "unifiedvol_tests"
            ]
        }
    ],
    "testPresets": [
        {
            "name": "linux-gcc-release-nonperformance",
            "configurePreset": "linux-gcc-release",
            "displayName": "Linux GCC Release tests except performance",
            "filter": {
                "exclude": {
                    "label": "performance"
                }
            },
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "linux-gcc-release-full",
            "configurePreset": "linux-gcc-release",
            "displayName": "Linux GCC Release full test suite",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "linux-gcc-release-unit",
            "configurePreset": "linux-gcc-release",
            "displayName": "Linux GCC Release unit tests",
            "filter": {
                "include": {
                    "label": "unit"
                }
            },
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "linux-gcc-release-integration",
            "configurePreset": "linux-gcc-release",
            "displayName": "Linux GCC Release integration tests",
            "filter": {
                "include": {
                    "label": "integration"
                }
            },
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "linux-gcc-release-regression",
            "configurePreset": "linux-gcc-release",
            "displayName": "Linux GCC Release regression tests",
            "filter": {
                "include": {
                    "label": "regression"
                }
            },
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "linux-gcc-perf-performance",
            "configurePreset": "linux-gcc-perf",
            "displayName": "Linux GCC perf build performance tests",
            "filter": {
                "include": {
                    "label": "performance"
                }
            },
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "linux-gcc-coverage-nonperformance",
            "configurePreset": "linux-gcc-coverage",
            "displayName": "Linux GCC coverage tests except performance",
            "filter": {
                "exclude": {
                    "label": "performance"
                }
            },
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}